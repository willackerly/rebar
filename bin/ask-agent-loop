#!/usr/bin/env bash
# ask-agent-loop — ASK Scoped Knowledge: standalone agent loop for use as run.sh
# CONTRACT:S2-ASK-CLI.1.0
#
# This script is the agent loop that watches an inbox, processes questions
# via claude, and writes responses to the outbox. It is invoked by `ask up`
# but can also be run directly or symlinked as an agent's run.sh.
#
# Usage:
#   ask-agent-loop <agent-dir>
#   # or, from within an agent directory:
#   ask-agent-loop .
#
# The agent directory must contain an AGENT.md file.

set -euo pipefail

AGENT_DIR="${1:-.}"
AGENT_DIR="$(cd "$AGENT_DIR" && pwd)"
AGENT_NAME="$(basename "$AGENT_DIR")"

INBOX="$AGENT_DIR/inbox"
OUTBOX="$AGENT_DIR/outbox"
SHARED_DIR="${ASK_SHARED_DIR:-$(dirname "$(dirname "$AGENT_DIR")")/shared}"
EVENTS_LOG="$SHARED_DIR/messages/events.jsonl"
MODEL="${ASK_MODEL:-sonnet}"
VERBOSE="${ASK_VERBOSE:-0}"

log() {
  if [ "$VERBOSE" = "1" ]; then
    echo "[$AGENT_NAME] $*" >&2
  fi
}

timestamp() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

append_event() {
  mkdir -p "$(dirname "$EVENTS_LOG")"
  echo "$1" >> "$EVENTS_LOG"
}

# Preflight checks
if [ ! -f "$AGENT_DIR/AGENT.md" ]; then
  echo "Error: $AGENT_DIR/AGENT.md not found" >&2
  exit 4
fi

if ! command -v claude &>/dev/null; then
  echo "Error: claude CLI not found" >&2
  exit 4
fi

if ! command -v jq &>/dev/null; then
  echo "Error: jq not found" >&2
  exit 4
fi

# Setup
mkdir -p "$INBOX" "$OUTBOX"
echo $$ > "$AGENT_DIR/.pid"
trap 'rm -f "$AGENT_DIR/.pid"; echo "[$AGENT_NAME] offline"; exit 0' EXIT INT TERM

echo "[$AGENT_NAME] online, watching $INBOX (pid $$)"

while true; do
  for msg in "$INBOX"/*.json; do
    [ -f "$msg" ] || continue

    MSG_ID=$(jq -r '.id' "$msg" 2>/dev/null || echo "unknown")
    QUESTION=$(jq -r '.body' "$msg" 2>/dev/null || echo "")
    FROM=$(jq -r '.from // "unknown"' "$msg" 2>/dev/null || echo "unknown")

    echo "[$AGENT_NAME] processing ($MSG_ID): $QUESTION"

    # Load context
    CONTEXT=$(cat "$AGENT_DIR/AGENT.md" 2>/dev/null || true)
    if [ -f "$AGENT_DIR/memory.md" ]; then
      CONTEXT="$CONTEXT

--- Current Memory ---
$(cat "$AGENT_DIR/memory.md")"
    fi

    # Invoke Claude
    PROMPT="You are the $AGENT_NAME agent.

Your role and context:
$CONTEXT

Question from $FROM: $QUESTION

Respond as JSON with these fields:
{
  \"answer\": \"your concise answer\",
  \"rationale\": \"your reasoning\",
  \"refs\": [\"relevant/file.md\"]
}

Rules:
- answer should be direct and concise
- rationale explains your reasoning briefly
- refs lists relevant files (empty array if none)
- respond ONLY with the JSON object, no other text"

    RESPONSE=$(claude --print --model "$MODEL" "$PROMPT" 2>/dev/null \
      || echo '{"answer": "error", "rationale": "claude invocation failed", "refs": []}')

    # Write response
    echo "$RESPONSE" > "$OUTBOX/$MSG_ID.json"

    # Log event
    TS=$(timestamp)
    EVENT=$(jq -n \
      --arg id "$MSG_ID" \
      --arg from "$AGENT_NAME" \
      --arg to "$FROM" \
      --arg type "answer" \
      --arg ts "$TS" \
      --arg body "$RESPONSE" \
      '{id: $id, from: $from, to: $to, type: $type, timestamp: $ts, body: $body}')
    append_event "$EVENT"

    # Memory log
    {
      echo "---"
      echo "**$TS** Q: $QUESTION"
      echo "A: $(echo "$RESPONSE" | jq -r '.answer' 2>/dev/null || echo "$RESPONSE" | head -1)"
    } >> "$AGENT_DIR/memory.log.md"

    # Consume
    rm "$msg"
    echo "[$AGENT_NAME] answered: $MSG_ID"
  done

  sleep 2
done
