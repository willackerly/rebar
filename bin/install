#!/usr/bin/env bash
# install — Add rebar's bin/ to PATH and optionally configure ASK_SERVER.
#
# Usage:
#   ./bin/install              # interactive
#   ./bin/install --server IP:PORT  # also set ASK_SERVER
#
# Idempotent — safe to run multiple times.

set -euo pipefail

BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
SHELL_NAME="$(basename "$SHELL")"

# Detect RC file
case "$SHELL_NAME" in
  zsh)  RC_FILE="$HOME/.zshrc" ;;
  bash) RC_FILE="$HOME/.bashrc" ;;
  *)    RC_FILE="$HOME/.profile" ;;
esac

# Parse args
ASK_SERVER_VAL=""
while [ $# -gt 0 ]; do
  case "$1" in
    --server) ASK_SERVER_VAL="$2"; shift 2 ;;
    --server=*) ASK_SERVER_VAL="${1#--server=}"; shift ;;
    -h|--help)
      echo "Usage: ./bin/install [--server HOST:PORT]"
      echo ""
      echo "Adds rebar bin/ to PATH in your shell RC file."
      echo "With --server, also sets ASK_SERVER for remote agent queries."
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

echo "rebar install"
echo "============="
echo ""

# --- PATH ---
PATH_LINE="export PATH=\"$BIN_DIR:\$PATH\""

if grep -qF "$BIN_DIR" "$RC_FILE" 2>/dev/null; then
  echo "[ok] PATH already includes $BIN_DIR"
else
  echo "" >> "$RC_FILE"
  echo "# rebar CLI tools (ask, ask-server)" >> "$RC_FILE"
  echo "$PATH_LINE" >> "$RC_FILE"
  echo "[added] PATH → $RC_FILE"
fi

# --- Tab completions ---
# Source the completion files from the RC file so `ask` and `rebar` get
# tab completion automatically. Idempotent: only adds if not already
# referenced. Bash and zsh have separate completion formats; we source
# whichever fits the user's shell.
COMPLETION_DIR="$BIN_DIR/completions"
if [ -d "$COMPLETION_DIR" ]; then
  case "$SHELL_NAME" in
    bash)
      if ! grep -qF "$COMPLETION_DIR/ask.bash" "$RC_FILE" 2>/dev/null; then
        echo "" >> "$RC_FILE"
        echo "# rebar tab completions (bash)" >> "$RC_FILE"
        echo "[ -f \"$COMPLETION_DIR/ask.bash\" ] && source \"$COMPLETION_DIR/ask.bash\"" >> "$RC_FILE"
        echo "[ -f \"$COMPLETION_DIR/rebar.bash\" ] && source \"$COMPLETION_DIR/rebar.bash\"" >> "$RC_FILE"
        echo "[added] tab completion (bash) → $RC_FILE"
      else
        echo "[ok] tab completion already wired"
      fi
      ;;
    zsh)
      if ! grep -qF "$COMPLETION_DIR" "$RC_FILE" 2>/dev/null; then
        echo "" >> "$RC_FILE"
        echo "# rebar tab completions (zsh)" >> "$RC_FILE"
        echo "fpath=(\"$COMPLETION_DIR\" \$fpath)" >> "$RC_FILE"
        echo "autoload -Uz compinit && compinit -u" >> "$RC_FILE"
        echo "[added] tab completion (zsh) → $RC_FILE"
      else
        echo "[ok] tab completion already wired"
      fi
      ;;
  esac
fi

# --- ASK_SERVER ---
if [ -n "$ASK_SERVER_VAL" ]; then
  if grep -qF "ASK_SERVER" "$RC_FILE" 2>/dev/null; then
    # Update existing value
    sed -i.bak "s|export ASK_SERVER=.*|export ASK_SERVER=$ASK_SERVER_VAL|" "$RC_FILE"
    rm -f "$RC_FILE.bak"
    echo "[updated] ASK_SERVER=$ASK_SERVER_VAL in $RC_FILE"
  else
    echo "export ASK_SERVER=$ASK_SERVER_VAL" >> "$RC_FILE"
    echo "[added] ASK_SERVER=$ASK_SERVER_VAL → $RC_FILE"
  fi
fi

echo ""
echo "Run this to apply now:"
echo ""
echo "  source $RC_FILE"
echo ""

# Verify dependencies
echo "Checking dependencies..."
ok=true
for dep in jq claude; do
  if command -v "$dep" &>/dev/null; then
    echo "  [ok] $dep"
  else
    echo "  [missing] $dep"
    ok=false
  fi
done

if command -v bash &>/dev/null; then
  bash_version=$(bash -c 'echo ${BASH_VERSINFO[0]}')
  if [ "$bash_version" -ge 3 ] 2>/dev/null; then
    echo "  [ok] bash $bash_version.x"
  else
    echo "  [warn] bash $bash_version.x (need 3.2+ — macOS default is fine)"
    ok=false
  fi
fi

if command -v python3 &>/dev/null; then
  echo "  [ok] python3 (for ask-server)"
else
  echo "  [missing] python3 (needed for ask-server)"
  ok=false
fi

echo ""
if [ "$ok" = true ]; then
  echo "Ready! Try: ask who"
else
  echo "Install missing dependencies above, then try: ask who"
fi
